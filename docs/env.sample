# EVE_CLIENT_SECRET=                  # Required for /sync_standings
# ESI_HTTP_TIMEOUT_SECS=15            # ESI/Fuzzwork/SSO client timeout
# KILLMAIL_PROCESS_TIMEOUT_SECS=60    # Max time per killmail before skip
# REDISQ_CONNECT_TIMEOUT_SECS=10     # RedisQ TCP connect timeout
# REDISQ_REQUEST_TIMEOUT_SECS=60     # RedisQ per-request timeout
# R2Z2_CONNECT_TIMEOUT_SECS=10       # R2Z2 TCP connect timeout
# R2Z2_REQUEST_TIMEOUT_SECS=15       # R2Z2 per-request timeout
# R2Z2_POLL_INTERVAL_SECS=6          # Min seconds between R2Z2 polls
# R2Z2_MAX_CONSECUTIVE_404S=10       # 404s before resync from sequence.json
# R2Z2_RESYNC_TIMEOUT_SECS=300       # Max seconds in 404 loop before resync
# KILLMAIL_FEED_PROVIDER=redisq      # "redisq" or "r2z2"
